{
  "name": "react-library-boilerplate",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/main.js",
  "module": "./dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b ./tsconfig.lib.json && vite build",
    "watch": "tsc -b ./tsconfig.lib.json --watch & vite build --watch",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "prettier": "^3.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass-embedded": "^1.99.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "unplugin-dts": "^1.0.0-beta.6",
    "vite": "^8.0.4",
    "vite-plugin-lib-inject-css": "^2.2.2"
  }
}
